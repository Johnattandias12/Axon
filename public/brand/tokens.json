{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "axon": {
    "version": "1.0.0",
    "color": {
      "ink": {
        "base": { "value": "#0A0A0B" },
        "2":    { "value": "#16161A" },
        "3":    { "value": "#2A2A2F" },
        "4":    { "value": "#4A4A52" }
      },
      "paper": {
        "base": { "value": "#FAFAF7" },
        "pure": { "value": "#FFFFFF" },
        "soft": { "value": "#F4F4EE" }
      },
      "mute": {
        "base": { "value": "#6B6B70" },
        "2":    { "value": "#9C9CA3" }
      },
      "rule": {
        "base":   { "value": "#E5E5E0" },
        "strong": { "value": "#C9C9C0" }
      },
      "pulse": {
        "base": { "value": "#C8FF00" },
        "deep": { "value": "#A2D900" },
        "soft": { "value": "#ECFFA8" },
        "ink":  { "value": "#0A0A0B" }
      },
      "semantic": {
        "success":      { "value": "#00B96B" },
        "success-soft": { "value": "#DAFBE6" },
        "warning":      { "value": "#E89400" },
        "warning-soft": { "value": "#FFF1CC" },
        "danger":       { "value": "#E5342B" },
        "danger-soft":  { "value": "#FFE1DE" },
        "info":         { "value": "#2D7AF6" },
        "info-soft":    { "value": "#DBE8FF" }
      }
    },
    "font": {
      "family": {
        "sans":    { "value": "Geist, Inter, system-ui, sans-serif" },
        "mono":    { "value": "JetBrains Mono, Geist Mono, ui-monospace, monospace" },
        "display": { "value": "Geist, Inter, system-ui, sans-serif" }
      },
      "weight": {
        "regular":  { "value": 400 },
        "medium":   { "value": 500 },
        "semibold": { "value": 600 },
        "bold":     { "value": 700 },
        "extrabold":{ "value": 800 }
      }
    },
    "radius": {
      "sm":   { "value": "4px" },
      "md":   { "value": "8px" },
      "lg":   { "value": "12px" },
      "xl":   { "value": "16px" },
      "2xl":  { "value": "24px" },
      "full": { "value": "9999px" }
    },
    "motion": {
      "duration": {
        "fast":   { "value": "120ms" },
        "normal": { "value": "200ms" },
        "slow":   { "value": "400ms" }
      },
      "easing": {
        "out":   { "value": "cubic-bezier(0.16, 1, 0.3, 1)" },
        "inout": { "value": "cubic-bezier(0.65, 0, 0.35, 1)" }
      }
    }
  }
}
