# ============================================================
# AXON — Variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_REF="xxxxx"
SUPABASE_DB_PASSWORD=""

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AXON"

# ─── QR Code HMAC (assinatura dos ingressos) ─────────────────
# Gere com: openssl rand -hex 32
# Em produção, configure também no Postgres:
#   ALTER DATABASE postgres SET app.qr_secret = '...';
QR_HMAC_SECRET=""

# ─── Pagar.me v5 (proposta D15 aceita em 18/05/2026) ─────────
# Doc: src/lib/payments/README.md + docs/financeiro/01-gateway-pagarme.md
# Webhook setup: docs/PAGARME-WEBHOOK-SETUP.md
# Sandbox: sk_test_* / pk_test_* | Produção: sk_live_* / pk_live_*
PAGARME_API_KEY="sk_test_..."
NEXT_PUBLIC_PAGARME_PUBLIC_KEY="pk_test_..."
# Secret do webhook criado no painel (whsec_...). Opcional em sandbox,
# obrigatório em produção (verifica HMAC do payload).
PAGARME_WEBHOOK_SECRET=""
# Recipient ID da AXON (re_/rp_...) para split com organizadores. Criar via
# POST /recipients no painel ou script. Necessário ao ativar split.
PAGARME_RECIPIENT_AXON=""
NEXT_PUBLIC_PAGARME_ENV="sandbox"

# ─── Resend (email transacional) ─────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AXON <noreply@axon.app>"
RESEND_REPLY_TO="suporte@axon.app"

# ─── Cloudflare Turnstile (antifraude no checkout) ───────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── Sentry (monitoramento) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="axon"
SENTRY_PROJECT="axon-web"

# ─── Admin emails (separa por vírgula) ───────────────────────
ADMIN_EMAILS="admin@axon.app,jdchefe@gmail.com"
SUPPORT_EMAIL="suporte@axon.app"

# ─── Google Gemini API ────────────────────────────────────────
GEMINI_API_KEY=""
