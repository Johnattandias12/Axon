# ============================================================
# AXON — Variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_REF="xxxxx"
SUPABASE_DB_PASSWORD=""

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AXON"

# ─── QR Code HMAC (assinatura dos ingressos) ─────────────────
# Gere com: openssl rand -hex 32
# Em produção, configure também no Postgres:
#   ALTER DATABASE postgres SET app.qr_secret = '...';
QR_HMAC_SECRET=""

# ─── Pagar.me v5 (em STANDBY até acordo com banco) ───────────
# Doc completa: src/lib/payments/README.md
PAGARME_API_KEY="sk_test_..."
NEXT_PUBLIC_PAGARME_PUBLIC_KEY="pk_test_..."
PAGARME_WEBHOOK_SECRET=""
PAGARME_RECIPIENT_AXON=""
NEXT_PUBLIC_PAGARME_ENV="sandbox"

# ─── Resend (email transacional) ─────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AXON <noreply@axon.app>"
RESEND_REPLY_TO="suporte@axon.app"

# ─── Cloudflare Turnstile (antifraude no checkout) ───────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── Sentry (monitoramento) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="axon"
SENTRY_PROJECT="axon-web"

# ─── Admin emails (separa por vírgula) ───────────────────────
ADMIN_EMAILS="admin@axon.com.br,jdchefe@gmail.com"
# Inbox real que recebe notificações cujo destinatário cai em ADMIN_EMAILS.
# Útil quando admin@axon.com.br ainda não tem mailbox real. Deixe vazio
# pra desligar o forward.
ADMIN_NOTIFICATIONS_EMAIL=""
SUPPORT_EMAIL="suporte@axon.app"

# ─── Setup / seed endpoints (DEV ONLY) ───────────────────────
# Usado por /api/admin/setup e /api/admin/seed. Em produção esses
# endpoints retornam 404 sempre, independente da var. Gere com:
#   openssl rand -hex 24
SETUP_SECRET=""

# ─── OAuth providers (configurar no Supabase Dashboard) ──────
# Não há env vars do lado da app — Google/Facebook OAuth é
# configurado em: Supabase > Authentication > Providers.
# Redirect URL a registrar nos providers:
#   https://<projeto>.supabase.co/auth/v1/callback
# Doc: https://supabase.com/docs/guides/auth/social-login
